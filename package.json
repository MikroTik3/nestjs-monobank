{
	"name": "nestjs-monobank",
	"version": "0.0.6",
	"private": true,
	"license": "MIT",
	"author": {
		"name": "MikroTik_2",
		"url": "https://docenko.vercel.app"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"dev:web": "turbo run dev --filter=web",
		"build:web": "turbo run build --filter=web",
		"build:packages": "turbo run build --filter=nestjs-monobank",
		"publish:packages": "npm run build:packages && lerna publish",
		"update": "npm update",
		"upgrade:all": "npm i -g npm-check-updates && ncu -u && npm install"
	},
	"devDependencies": {
		"baseline-browser-mapping": "^2.10.0",
		"turbo": "^2.3.1"
	},
	"packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4"
}
