{
	"name": "nestjs-monobank",
	"version": "0.0.6",
	"private": true,
	"license": "MIT",
	"author": {
		"name": "MikroTik_2",
		"url": "https://docenko.vercel.app"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"dev:web": "turbo run dev --filter=web",
		"build:web": "turbo run build --filter=web",
		"build:packages": "turbo run build --filter=nestjs-monobank",
		"publish:packages": "npm run build:packages && lerna publish",
              "update": "pnpm update",
              "upgrade:all": "pnpm dlx npm-check-updates -u && pnpm install"
	},
	"devDependencies": {
		"baseline-browser-mapping": "^2.11.0",
		"turbo": "^2.10.5"
	},
	"packageManager": "pnpm@10.30.2"
}
